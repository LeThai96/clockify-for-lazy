# Required
CLOCKIFY_API_KEY=your_clockify_api_key
CLOCKIFY_WORKSPACE_ID=your_workspace_id

# Optional
CLOCKIFY_PROJECT_ID=your_project_id
TIMEZONE=Asia/Bangkok
WORKDAY_START=09:00
WORKDAY_END=18:00

# Entry generation
MIN_ENTRIES=3
MAX_ENTRIES=5
MIN_MINUTES=30
MAX_MINUTES=120
TOTAL_MINUTES=480
STEP_MINUTES=5

# Date selection (use either single date OR start/end range, not both)
# CLOCKIFY_TARGET_DATE=2026-04-21
# CLOCKIFY_START_DATE=2026-04-01
# CLOCKIFY_END_DATE=2026-04-30
# DAY_OFF creates one non-billable "Day off" entry per listed date
DAY_OFF=2026-04-07,2026-04-15

# Optional skip/behavior flags
# IGNORE_DAY_HAS_ENTRIES=0
# DRY_RUN=0
# CLOCKIFY_DEBUG=0
# CLOCKIFY_RANDOM_SEED=42

# PUBLIC_HOLIDAYS creates one non-billable "Public holiday" entry per listed date
PUBLIC_HOLIDAYS=2026-01-01,2026-04-30,2026-05-01
